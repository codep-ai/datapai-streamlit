# ─────────────────────────────────────────────────────────────────────────────
# Datap.ai Trace Ledger — environment variable reference
#
# Copy this file to .env and fill in values for your environment.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────


# ── Backend selection ─────────────────────────────────────────────────────────

# Which storage backend to use.
# Options: sqlite (default, local dev) | snowflake (cloud/prod) | null (disabled)
DATAPAI_TRACE_BACKEND=sqlite

# Set to false to completely disable trace event emission (useful in tests).
DATAPAI_TRACE_ENABLED=true


# ── SQLite backend (local development) ───────────────────────────────────────

# Path to the SQLite database file for local trace storage.
# Default: datapai_traces.db (in the repo root, gitignored)
DATAPAI_TRACE_SQLITE_PATH=datapai_traces.db


# ── Snowflake backend (cloud / production) ───────────────────────────────────
#
# These are the same credentials used by dbt-traceability (via profiles.yml).
# The Snowflake backend writes to: <SNOWFLAKE_DATABASE>.<SNOWFLAKE_SCHEMA>.DATAPAI_TRACE_EVENTS

# Snowflake account identifier (e.g. xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=

# Service account user with INSERT + CREATE TABLE on the trace schema
SNOWFLAKE_USER=

# Password (or use key-pair auth below instead)
SNOWFLAKE_PASSWORD=

# Optional: RSA private key file path (alternative to password)
# SNOWFLAKE_PRIVATE_KEY_PATH=/path/to/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=

SNOWFLAKE_DATABASE=DATAPAI_DB
SNOWFLAKE_SCHEMA=DATAPAI_TRACES        # Schema where trace events are written
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=DATAPAI_TRACE_ROLE

# Override the default table name (default: DATAPAI_TRACE_EVENTS)
# DATAPAI_TRACE_SNOWFLAKE_TABLE=DATAPAI_TRACE_EVENTS

# Batch size for Snowflake MERGE inserts (default: 50)
# DATAPAI_TRACE_SNOWFLAKE_BATCH=50


# ── Identity context (for ETL / background jobs) ──────────────────────────────
#
# When running outside of a Streamlit session (e.g. Airflow, CLI, tests),
# set these to provide identity context to IdentityContext.from_env().

DATAPAI_TENANT_ID=default
DATAPAI_WORKSPACE_ID=default
DATAPAI_USER_ID=system
# DATAPAI_SESSION_ID=  (auto-generated UUID if not set)


# ── Existing env vars used by the ETL audit bridge ───────────────────────────
#
# The traceability module bridges to agents/etl/audit.py via etl_run_id.
# These are already set by the existing ETL system:

# DUCKDB_PATH=datapai.duckdb
# ETL_AUDIT_LOG=etl_audit.jsonl
# DATAPAI_ENV=dev


# ── dbt-traceability (for running dbt commands) ───────────────────────────────
#
# The dbt-traceability project uses the datapai_snowflake profile.
# The Snowflake variables above are shared with dbt.
# Set DBT_PROJECT_DIR if running dbt from a different working directory:

# DBT_PROJECT_DIR=dbt-traceability


# ─────────────────────────────────────────────────────────────────────────────
# Quickstart: local development
#
#   DATAPAI_TRACE_BACKEND=sqlite
#   DATAPAI_TRACE_SQLITE_PATH=datapai_traces.db
#   DATAPAI_TENANT_ID=dev-tenant
#   DATAPAI_USER_ID=developer
#
# Quickstart: cloud production (Snowflake)
#
#   DATAPAI_TRACE_BACKEND=snowflake
#   SNOWFLAKE_ACCOUNT=xy12345.us-east-1
#   SNOWFLAKE_USER=datapai_svc
#   SNOWFLAKE_PASSWORD=<secret>
#   SNOWFLAKE_DATABASE=DATAPAI_PROD
#   SNOWFLAKE_SCHEMA=DATAPAI_TRACES
#   SNOWFLAKE_WAREHOUSE=COMPUTE_WH
#   SNOWFLAKE_ROLE=DATAPAI_TRACE_ROLE
# ─────────────────────────────────────────────────────────────────────────────
